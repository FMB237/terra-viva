# Terra Viva Royalty Day — ENSPM Maroua
# Copy to .env and fill in your values

# App
SECRET_KEY=change-this-to-a-random-secret-key-in-production
DB_PATH=terra_viva.db
VOTE_PRICE=100

# Campay (handles both Orange Money & MTN MoMo for Cameroon)
# Sign up at https://campay.net/en/developers
CAMPAY_APP_USERNAME=
CAMPAY_APP_PASSWORD=
# Use https://demo.campay.net/api for sandbox, https://campay.net/api for prod
CAMPAY_BASE_URL=https://demo.campay.net/api

# Webhook URL (register in your Campay dashboard)
# https://yourdomain.com/api/payments/callback

# Optional: direct Orange Money credentials (if not using Campay)
# ORANGE_MONEY_CLIENT_ID=
# ORANGE_MONEY_CLIENT_SECRET=

# Optional: direct MTN MoMo credentials (sandbox from https://momodeveloper.mtn.com)
# MTN_SUBSCRIPTION_KEY=
# MTN_API_USER=
# MTN_API_KEY=
